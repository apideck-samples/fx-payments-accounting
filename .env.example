# ─────────────────────────────────────────────────────────────────────────
# The demo runs with ZERO credentials — it serves bundled mock data that
# mirrors the real Apideck unified Accounting API shapes. Fill these in to
# flip the in-app toggle to "Live" and proxy the same calls to your own
# Apideck app against a real ERP connection.
#
#   https://app.apideck.com  →  Settings → Secrets
# ─────────────────────────────────────────────────────────────────────────

# APIDECK_API_KEY=sk_live_or_test_xxx
# APIDECK_APP_ID=your_app_id

# The consumer whose ERP connection the calls are scoped to (your end customer).
# APIDECK_DEFAULT_CONSUMER_ID=lumen-interiors

# The ERP connector the payables are read from / written back to.
# netsuite | quickbooks | xero | sage-intacct | business-central | exact-online
# APIDECK_SERVICE_ID=netsuite
